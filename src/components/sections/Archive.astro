<section id="archive" class="section" aria-labelledby="archive-heading">
  <h2 id="archive-heading" class="section__heading">Tư liệu biểu diễn</h2>

  <p class="section__intro">
    Hình ảnh thật từ những lần đứng tại booth, poster và không gian sự kiện.
  </p>

  <div class="show-gallery">
    <figure class="show-card show-card--portrait card--reveal">
      <a href="/assets/show/dj-performing-01.webp" target="_blank" rel="noopener">
        <img src="/assets/show/dj-performing-01.webp"
             alt="Minh Hiếu đang điều khiển bàn DJ tại Six T Club"
             loading="lazy" width="1400" height="1800">
      </a>
      <figcaption>Khoảnh khắc làm việc trực tiếp tại booth.</figcaption>
    </figure>

    <figure class="show-card show-card--hero card--reveal">
      <a href="/assets/show/dj-performing-02.webp" target="_blank" rel="noopener">
        <img src="/assets/show/dj-performing-02.webp"
             alt="Minh Hiếu biểu diễn DJ dưới hệ thống laser sân khấu"
             loading="lazy" width="1400" height="1400">
      </a>
      <figcaption>Tương tác với không gian và khán giả trong buổi diễn.</figcaption>
    </figure>

    <figure class="show-card show-card--poster card--reveal">
      <a href="/assets/show/guest-dj-poster.webp" target="_blank" rel="noopener">
        <img src="/assets/show/guest-dj-poster.webp"
             alt="Poster Guest DJ tại Six T Club ngày 12 tháng 3 năm 2024"
             loading="lazy" width="1200" height="1500">
      </a>
      <figcaption>Poster Guest DJ — Six T Club, 12.03.2024.</figcaption>
    </figure>

    <figure class="show-card show-card--wide card--reveal">
      <a href="/assets/show/six-t-club-stage.webp" target="_blank" rel="noopener">
        <img src="/assets/show/six-t-club-stage.webp"
             alt="Sân khấu Six T Club hiển thị poster Guest DJ"
             loading="lazy" width="1600" height="1200">
      </a>
      <figcaption>Poster được trình chiếu trực tiếp trên màn hình sân khấu.</figcaption>
    </figure>

    <figure class="show-card show-card--square card--reveal">
      <a href="/assets/show/dj-red-stage.webp" target="_blank" rel="noopener">
        <img src="/assets/show/dj-red-stage.webp"
             alt="Ảnh tại booth DJ trong một sự kiện sân khấu"
             loading="lazy" width="1400" height="1400">
      </a>
      <figcaption>Một khoảnh khắc khác phía sau bàn DJ.</figcaption>
    </figure>
  </div>
</section>
