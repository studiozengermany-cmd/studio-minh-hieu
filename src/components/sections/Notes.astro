---
import type { SiteCopy } from '../../i18n';

interface Props {
  copy: SiteCopy['notes'];
}

const { copy } = Astro.props;
---

<section id="notes" class="section" aria-labelledby="notes-heading">
  <h2 id="notes-heading" class="section__heading">{copy.heading}</h2>

  <p class="section__intro">{copy.intro}</p>

  <div class="notes-list">
    {copy.items.map((item) => (
      <div class="doppelrand">
        <details class="content-detail card--reveal">
          <summary>
            <span>
              <span class="content-detail__kicker">{item.kicker}</span>
              <strong>{item.title}</strong>
            </span>
            <span class="content-detail__action" data-closed={item.closedLabel}>{item.closedLabel}</span>
          </summary>
          <div class="content-detail__body">
            <p>{item.body}</p>
          </div>
        </details>
      </div>
    ))}
  </div>
</section>
