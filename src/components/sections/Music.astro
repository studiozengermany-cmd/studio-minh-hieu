---
import type { SiteCopy } from '../../i18n';

interface Props {
  copy: SiteCopy['music'];
}

const { copy } = Astro.props;
---

<section id="music" class="section" aria-labelledby="music-heading">
  <h2 id="music-heading" class="section__heading">{copy.heading}</h2>

  <p class="section__intro">{copy.intro}</p>

  <article class="featured-track card--reveal">
    <div class="featured-track__cover">
      <img src="/assets/images/lieu-thanh-yen-remix-cover.webp"
           alt={copy.coverAlt}
           loading="lazy" width="1200" height="1200">
    </div>

    <div class="featured-track__body">
      <span class="content-detail__kicker">{copy.kicker}</span>
      <h3>{copy.trackTitle}</h3>
      <p class="featured-track__version">{copy.version}</p>

      <p>{copy.description}</p>

      <audio class="track-player"
             controls
             preload="metadata"
             controlsList="nodownload"
             aria-label={copy.audioLabel}>
        <source src="/assets/audio/lieu-thanh-yen-j97-minh-hieu-remix-2k26-preview.mp3" type="audio/mpeg">
        {copy.audioFallback}
      </audio>

      <div class="track-meta" aria-label={copy.metaLabel}>
        {copy.meta.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </article>

  <div class="content-grid music-workflow-grid">
    {copy.details.map((detail, index) => (
      <div class="doppelrand">
        <details class="content-detail card--reveal" open={index === 0}>
          <summary>
            <span>
              <span class="content-detail__kicker">{detail.kicker}</span>
              <strong>{detail.title}</strong>
            </span>
            <span class="content-detail__action" data-closed={detail.closedLabel}>{detail.closedLabel}</span>
          </summary>
          <div class="content-detail__body">
            <p>{detail.body}</p>
          </div>
        </details>
      </div>
    ))}
  </div>
</section>
