---
import type { SiteCopy } from '../i18n';

interface Props {
  copy: SiteCopy['footer'];
}

const { copy } = Astro.props;
const email = 'admin@studiominhhieu.com';
---

<footer class="cinematic-footer" role="contentinfo">
  <div class="cinematic-footer__bottom">
    <div class="footer-contact-links">
      {copy.links.map((link) => (
        <a href={link.subject ? `mailto:${email}?subject=${encodeURIComponent(link.subject)}` : `mailto:${email}`}>
          {link.label}
        </a>
      ))}
    </div>
    <span>{copy.copyright}</span>
  </div>
</footer>
